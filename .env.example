# ============================================================
# E-Challan System - Environment Variables
# Copy to .env and fill in values
# ============================================================

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=echallan_db
DB_USERNAME=echallan_user
DB_PASSWORD=echallan_pass

# --- JWT (generate a strong 256-bit base64-encoded secret) ---
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# --- Blockchain ---
BLOCKCHAIN_NODE_URL=http://localhost:8545
BLOCKCHAIN_ADMIN_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
CHALLAN_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
GAS_LIMIT=6721975
GAS_PRICE=20000000000

# --- IPFS ---
IPFS_HOST=localhost
IPFS_PORT=5001
IPFS_PROTOCOL=http
IPFS_GATEWAY_URL=http://localhost:8080/ipfs

# --- Server ---
SERVER_PORT=8080
